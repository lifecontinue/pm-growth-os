# App
APP_BASE_URL=http://localhost:5174
PORT=8787
VITE_API_URL=http://localhost:8787

# Database/Auth for production
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
METABASE_SITE_URL=
VSCODE_USAGE_BRIDGE_TOKEN=

# LLM providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional MCP endpoints
MCP_MEMORY_URL=
MCP_GITHUB_URL=

# Real web search provider for Knowledge Tool
# SEARCH_PROVIDER can be tavily, brave, or serpapi. If omitted, the API
# auto-selects the first configured provider in that order.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Observability / tracing
WANDB_API_KEY=
WANDB_PROJECT=pm-growth-os
WEAVE_PROJECT=pm-growth-os

# Langfuse tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Optional integrations
NOTION_TOKEN=
NOTION_DATABASE_ID=
GITHUB_TOKEN=
LARK_APP_ID=
LARK_APP_SECRET=
